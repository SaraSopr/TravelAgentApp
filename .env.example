APP_NAME=TravelAgentApp
ENV=dev
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

BUS_BACKEND=inmemory
NATS_URL=nats://localhost:4222
NATS_CONNECT_RETRIES=20
NATS_CONNECT_DELAY_MS=500

POSTGRES_DSN=postgresql+asyncpg://postgres:postgres@localhost:5432/travel_agent
REDIS_URL=redis://localhost:6379/0
STATE_BACKEND=memory

OBSERVER_POLL_SECONDS=30
OBSERVER_ENABLED=true
OBSERVER_MAX_EVENTS_PER_CYCLE=20

NEWS_API_URL=https://newsapi.org/v2/everything
NEWS_API_KEY=
TRANSIT_ALERTS_URL=
SOCIAL_SIGNALS_URL=

THREAT_IMPACT_THRESHOLD=0.65
REPLAN_COOLDOWN_SECONDS=180

BUS_MAX_RETRIES=2
BUS_RETRY_BASE_MS=150

OTEL_ENABLED=false
OTEL_SERVICE_NAME=travel-agent-app
OTEL_EXPORTER_ENDPOINT=

AUTH_SECRET=dev-secret-change-me
AUTH_TOKEN_TTL_MINUTES=120
AUTH_LOGIN_MAX_ATTEMPTS=8
AUTH_LOGIN_WINDOW_SECONDS=60
AUTH_LOGIN_LOCK_SECONDS=120
